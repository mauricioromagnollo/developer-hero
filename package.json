{
  "name": "doe-backend",
  "version": "0.0.1",
  "description": "Backend do aplicativo Doe.",
  "author": "Maurício Romagnoli ~ x0n4d0 <romagnolimauricio@gmail.com>",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "nest start",
    "dev": "STAGE=dev nest start --watch",
    "dev:docker": "STAGE=dev docker-compose --env-file .env.dev up",
    "prod": "STAGE=prod node dist/main",
    "debug": "STAGE=dev nest start --debug --watch",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "husky install",
    "test": "STAGE=test jest --passWithNoTests --runInBand --no-cache",
    "test:watch": "npm test -- --watch",
    "test:cov": "npm test -- --coverage",
    "test:unit": "npm test -- -c jest-unit.config.js",
    "test:int": "npm test -- -c jest-int.config.js",
    "test:e2e": "npm test -- -c jest-e2e.config.js",
    "test:staged": "npm test -- --findRelatedTests",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@hapi/joi": "^17.1.1",
    "@nestjs/common": "^8.0.0",
    "@nestjs/config": "^2.0.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/platform-express": "^8.0.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@nestjs/cli": "^8.0.0",
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@types/express": "^4.17.13",
    "@types/hapi__joi": "^17.1.8",
    "@types/jest": "27.4.1",
    "@types/node": "^16.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^7.0.4",
    "jest": "^27.2.5",
    "lint-staged": "^12.4.0",
    "mrm": "^2.6.2",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^27.0.3",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^3.10.1",
    "typescript": "^4.3.5"
  },
  "engines": {
    "node": "18.x"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
